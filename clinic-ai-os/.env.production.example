# ============================================================
# Clinic AI OS — Production Environment Variables
# ============================================================
# Copy this to .env.production for Vercel deployment
# Fill in your production values — all fields required
# ============================================================

# ── Supabase ───────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# Service role key — NEVER expose to client bundle
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# ── WhatsApp (Meta Cloud API) ────────────────────────────
# Phone Number ID from Meta WhatsApp Business → Add Product → WhatsApp → Get Started
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Access token from Meta Developer Console → WhatsApp → Basic Settings
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verify token — any random string you choose, must match in Meta webhook config
WHATSAPP_VERIFY_TOKEN=your-random-secret-token-here

# Business Account ID from Meta WhatsApp → Overview
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345

# ── AI Provider ─────────────────────────────────────────
# Options: openai | gemini | deterministic
# Use 'openai' or 'gemini' in production for real AI responses
AI_PROVIDER=openai

# For OpenAI (recommended for production Arabic AI)
OPENAI_API_KEY=sk-xxx...xxxx

# For Google Gemini (free tier available)
GEMINI_API_KEY=AIzaxx...xxxx

# ── App Config ───────────────────────────────────────────
# Your deployed URL (no trailing slash)
APP_URL=https://your-domain.vercel.app

# Set to 'false' in production when using real WhatsApp + AI provider
MOCK_MODE=false
