# ============================================================
# Nasaq — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# ── Supabase ───────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key — NEVER expose to client bundle
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── WhatsApp (Meta Cloud API) ────────────────────────────
# Phone Number ID from Meta WhatsApp Business → Add Product → WhatsApp → Get Started
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Access token from Meta Developer Console → WhatsApp → Basic Settings
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verify token — any random string you choose, must match in Meta webhook config
WHATSAPP_VERIFY_TOKEN=your-random-secret-token-here

# App secret from Meta Developer Console; validates webhook signatures in production
WHATSAPP_APP_SECRET=your-meta-app-secret

# Business Account ID from Meta WhatsApp → Overview
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345

# ── AI Provider ─────────────────────────────────────────
# Options: deterministic | openai | gemini
# Leave empty to use deterministic demo AI (no API key needed)
AI_PROVIDER=deterministic

# For OpenAI (recommended for production Arabic AI)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# For Google Gemini (free tier available)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App Config ───────────────────────────────────────────
# Your deployed URL (no trailing slash)
APP_URL=https://your-domain.vercel.app

# Set to 'false' when running with real credentials
# 'true' uses mock WhatsApp sender + deterministic AI
MOCK_MODE=true

# Production safety switch. Keep false unless intentionally exposing demo APIs.
ENABLE_UNAUTHENTICATED_DEMO_API=false

# ── Optional ────────────────────────────────────────────
# NextAuth secret (generate with: openssl rand -base64 32)
# NEXTAUTH_SECRET=your-nextauth-secret

# NextAuth URL
# NEXTAUTH_URL=https://your-domain.vercel.app

# ── Demo Auth Credentials ───────────────────────────────
# Used for the demo MVP login
DEMO_EMAIL=owner@clinic.com
DEMO_PASSWORD=demo1234
